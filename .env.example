# Telegram
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_ADMIN_USER_ID=       # Your Telegram user ID (get from @userinfobot)

# OpenRouter (free tier)
OPENROUTER_API_KEY=           # From openrouter.ai

# Supabase
SUPABASE_URL=                 # https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=            # From Supabase Dashboard → API
SUPABASE_SERVICE_KEY=         # From Supabase Dashboard → API
SUPABASE_DB_URL=              # postgresql://postgres:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Email (Gmail IMAP/SMTP)
EMAIL_ADDRESS=                # your@gmail.com
EMAIL_PASSWORD=               # App-specific password (NOT your main password)
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Google API (Calendar)
GOOGLE_CREDENTIALS_JSON=      # Base64-encoded service account JSON

# System settings
LOG_LEVEL=INFO
ENVIRONMENT=development
TOKEN_THRESHOLD=5000
APPROVAL_TIMEOUT_HOURS=24
HEALTH_PORT=8000
